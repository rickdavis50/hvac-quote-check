# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Payments (Stripe) — required for the $9 unlock ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
# APP_URL is the public origin used for Stripe Checkout return links.
# MUST be set in production or paying customers return to localhost.
# APP_URL=https://your-domain.example

# --- Admin ---
ADMIN_KEY=change-me

# --- Server ---
API_PORT=5178
# Hosting proxy hops to trust for client IPs / rate limiting (Railway = 1).
# TRUST_PROXY=1

# --- Persistence ---
# Results + share links + payment state. The store is chosen automatically:
#
# Vercel (serverless): set Supabase credentials. The service_role key is used
# server-side only (RLS-sealed table; the browser never touches this store).
# Required for result links and paid unlocks to persist across invocations.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...            # Supabase → Project Settings → API
# HVAC_SUBMISSIONS_TABLE=submissions       # set to hvac_submissions if sharing a project
#
# Railway / a persistent disk: leave Supabase unset and point these at a volume.
# HVAC_SUBMISSIONS_DIR=/data/submissions
# HVAC_KNOWLEDGE_DIR=/data/knowledge
#
# APP_URL (above) must be your real Vercel domain in production for Stripe returns.

# --- Rate limiting (per-IP, protects the Claude budget) ---
# RATE_LIMIT_WINDOW_MIN=15
# RATE_LIMIT_MAX=20
# RATE_LIMIT_MCP_MAX=60

# --- Client analytics (Vite, exposed to the browser) ---
# Google Analytics 4 Measurement ID. Analytics is fully disabled until this is set
# (every event becomes a no-op / dev-console log). Configured for first-party
# measurement only: IP anonymization on, Google ad/cross-site signals off, and
# skipped entirely for visitors sending Global Privacy Control or Do Not Track.
# Create a GA4 property → Admin → Data Streams → Web → copy the Measurement ID.
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
