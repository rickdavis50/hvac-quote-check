# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Payments (Stripe) — required for the $9 unlock ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
# APP_URL is the public origin used for Stripe Checkout return links.
# MUST be set in production or paying customers return to localhost.
# APP_URL=https://your-domain.example

# --- Admin ---
ADMIN_KEY=change-me

# --- Server ---
API_PORT=5178
# Hosting proxy hops to trust for client IPs / rate limiting (Railway = 1).
# TRUST_PROXY=1

# --- Persistence (point these at a mounted volume in production) ---
# Paid reports + share links live here — must survive redeploys.
# HVAC_SUBMISSIONS_DIR=/data/submissions
# Accumulated benchmark quotes. Seed data ships in the image at ./knowledge.
# HVAC_KNOWLEDGE_DIR=/data/knowledge

# --- Rate limiting (per-IP, protects the Claude budget) ---
# RATE_LIMIT_WINDOW_MIN=15
# RATE_LIMIT_MAX=20
# RATE_LIMIT_MCP_MAX=60
